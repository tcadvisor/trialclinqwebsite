# Azure Entra ID Configuration
# Get these values from Azure Portal > Azure Entra ID > App registrations > TrialCliniq

# Azure Entra ID Application (Client) ID
VITE_AZURE_CLIENT_ID=your-azure-client-id-here

# Azure Tenant ID (Directory ID)
VITE_AZURE_TENANT_ID=your-azure-tenant-id-here

# Redirect URI after sign-in (must match app registration)
VITE_AZURE_REDIRECT_URI=https://app.trialcliniq.com/auth-callback

# Logout redirect URI (optional)
VITE_AZURE_LOGOUT_URI=https://app.trialcliniq.com/

# API Scopes (optional, for API access)
VITE_AZURE_SCOPES=User.Read email profile openid

# EPIC FHIR Integration
VITE_EPIC_CLIENT_ID=your-epic-client-id
VITE_EPIC_REDIRECT_URI=https://app.trialcliniq.com/patients/ehr-callback
VITE_EPIC_FHIR_URL=https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4/

# Database (PostgreSQL)
# Set either DATABASE_URL or the individual PG* variables below.
DATABASE_URL=postgresql://username:password@hostname:5432/database_name?sslmode=require
PGHOST=your-postgres-host
PGUSER=your-postgres-user
PGPASSWORD=your-postgres-password
PGPORT=5432
PGDATABASE=your-database-name

# Azure Storage
AZURE_STORAGE_ACCOUNT_NAME=your-storage-account-name
AZURE_STORAGE_ACCOUNT_KEY=your-storage-account-key

# AI Summarization (Netlify Functions)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_SUMMARIZE_MODEL=gpt-4o-mini


# Email sender address used by Resend (defaults to noreply@trialcliniq.com)
EMAIL_FROM=noreply@trialcliniq.com

# Sentry Error Tracking
# Get your DSN from https://sentry.io -> Project Settings -> Client Keys
VITE_SENTRY_DSN=https://your-key@o0.ingest.sentry.io/0
SENTRY_DSN=https://your-key@o0.ingest.sentry.io/0

# CSRF Protection
# Generate with: openssl rand -hex 32
CSRF_SECRET=

# Allowed origins for CORS
ALLOWED_ORIGINS=https://app.trialcliniq.com

# Resend (transactional email)
RESEND_API_KEY=

# Runtime environment
NODE_ENV=production
