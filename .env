# ============================================================================
# REQUIRED: Azure Entra ID Configuration
# Get these values from Azure Portal > Azure Entra ID > App registrations
# ============================================================================
VITE_AZURE_CLIENT_ID=your-client-id-here
VITE_AZURE_TENANT_ID=your-tenant-id-here
VITE_AZURE_REDIRECT_URI=http://localhost:5173/auth-callback
VITE_AZURE_LOGOUT_URI=http://localhost:5173/
VITE_AZURE_SCOPES=User.Read email profile openid

# ============================================================================
# REQUIRED: Database (PostgreSQL on Neon, Supabase, or Azure)
# For Neon: Get connection string from console.neon.tech
# For Supabase: Get from project settings > Database
# ============================================================================
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require
PGHOST=your-host.neon.tech
PGUSER=your-username
PGPASSWORD=your-password
PGPORT=5432
PGDATABASE=your-database

# ============================================================================
# REQUIRED: Azure Blob Storage (for medical document uploads)
# Get from Azure Portal > Storage Account > Access Keys
# ============================================================================
AZURE_STORAGE_ACCOUNT_NAME=your-storage-account
AZURE_STORAGE_ACCOUNT_KEY=your-storage-key

# AI Summarization (Netlify Functions)
OPENAI_API_KEY=
OPENAI_SUMMARIZE_MODEL=gpt-4o-mini

# ============================================================================
# Elation Health EHR Integration (Sandbox)
# ============================================================================

# Environment: sandbox or production
ELATION_ENVIRONMENT=sandbox

